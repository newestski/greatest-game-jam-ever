[gd_scene format=3 uid="uid://b41onetcmh4ne"]

[sub_resource type="GDScript" id="GDScript_ojb23"]
resource_name = "game_ui"
script/source = "extends Control

@onready var health_bar: ProgressBar = $Control/VBoxContainer/HealthBar
@onready var energy_bar: ProgressBar = $Control/VBoxContainer/EnergyBar
@onready var floor_counter: Label = $FloorCounter
@onready var player: Player = %Player
@onready var game_manager: GameManager = %GameManager

func _process(_delta: float) -> void:
	if player:
		health_bar.value = player.health_component.health
		health_bar.max_value = player.health_component.max_health
		energy_bar.value = player.energy
		energy_bar.max_value = player.max_energy
		floor_counter.text = \"floor \" + str(game_manager.current_floor)
"

