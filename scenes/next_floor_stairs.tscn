[sub_resource type="GDScript" id="GDScript_phsuj"]
resource_name = "next_floor_stairs"
script/source = "extends Node2D

@onready var area_2d: Area2D = $Area2D
@onready var game_manager: GameManager
@onready var player: Player
@onready var dialog: DialogSystem
@onready var sprite: Sprite2D = $Sprite2D
@onready var audio_stream_player_2d: AudioStreamPlayer2D = $AudioStreamPlayer2D

@export var open_region: Rect2
@export var closed_region: Rect2

func _ready():
	player = get_tree().get_first_node_in_group(\"player\")
	game_manager = get_tree().get_first_node_in_group(\"game_manager\")
	
	game_manager.floor_cleared.connect(open_door)
	
	if game_manager.enemies_left == 0:
		sprite.region_rect = open_region
	else:
		sprite.region_rect = closed_region

func open_door():
	sprite.region_rect = open_region
	audio_stream_player_2d.play()

func _on_area_2d_body_entered(body: Node2D) -> void:
	if !dialog:
		if body == player and game_manager.enemies_left == 0:
			game_manager.go_to_next_floor()
	else:
		if body == player and game_manager.enemies_left == 0 and dialog.in_dialog == false:
			game_manager.go_to_next_floor()
"

